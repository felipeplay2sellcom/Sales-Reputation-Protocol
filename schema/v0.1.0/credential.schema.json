{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://salesreputationprotocol.org/schema/v0.1.0/credential.schema.json",
  "title": "SRP Credential",
  "description": "A verifiable sales reputation credential conforming to W3C VC 2.0.",
  "type": "object",
  "required": ["@context", "id", "type", "issuer", "validFrom", "credentialSubject"],
  "properties": {
    "@context": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "contains": { "const": "https://www.w3.org/ns/credentials/v2" },
      "description": "JSON-LD context. MUST include the W3C VC v2 context."
    },
    "id": {
      "type": "string",
      "description": "Unique credential identifier (URN or URL)."
    },
    "type": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "VerifiableCredential" },
      "description": "Credential types. MUST include 'VerifiableCredential'."
    },
    "issuer": {
      "oneOf": [
        { "type": "string", "pattern": "^did:" },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": { "type": "string", "pattern": "^did:" },
            "type": { "type": "string" },
            "name": { "type": "string" },
            "industry": { "type": "string" }
          }
        }
      ],
      "description": "Credential issuer (DID string or object with metadata)."
    },
    "validFrom": {
      "type": "string",
      "format": "date-time",
      "description": "Date from which the credential is valid."
    },
    "validUntil": {
      "type": "string",
      "format": "date-time",
      "description": "Date after which the credential expires."
    },
    "credentialSubject": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^did:",
          "description": "DID of the credential subject (sales professional)."
        },
        "type": {
          "type": "string",
          "enum": [
            "SalesAchievementSubject",
            "SalesScoreSubject",
            "SalesEndorsementSubject"
          ]
        },
        "achievement": { "$ref": "#/$defs/achievement" },
        "score": { "$ref": "#/$defs/score" },
        "endorsement": { "$ref": "#/$defs/endorsement" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        }
      },
      "description": "The subject and claims of the credential."
    },
    "credentialStatus": {
      "type": "object",
      "required": ["id", "type", "statusPurpose"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "const": "BitstringStatusListEntry" },
        "statusPurpose": { "type": "string", "enum": ["revocation", "suspension"] },
        "statusListIndex": { "type": "string" },
        "statusListCredential": { "type": "string", "format": "uri" }
      },
      "description": "Revocation/suspension status information."
    },
    "proof": {
      "oneOf": [
        { "$ref": "#/$defs/proof" },
        { "type": "array", "items": { "$ref": "#/$defs/proof" } }
      ],
      "description": "Cryptographic proof(s) for the credential."
    }
  },
  "additionalProperties": true,
  "$defs": {
    "achievement": {
      "type": "object",
      "required": ["type", "name"],
      "properties": {
        "type": { "type": "string", "const": "SalesAchievement" },
        "name": { "type": "string", "description": "Human-readable achievement name." },
        "description": { "type": "string" },
        "criteria": {
          "type": "object",
          "properties": {
            "narrative": { "type": "string" }
          }
        },
        "salesCategory": {
          "type": "string",
          "enum": [
            "deal_milestone", "revenue_milestone", "quota_achievement",
            "ranking", "certification", "training", "mission",
            "client_impact", "peer_recognition"
          ]
        },
        "industry": { "type": "string" },
        "image": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "format": "uri" },
            "type": { "type": "string", "const": "Image" }
          }
        }
      }
    },
    "score": {
      "type": "object",
      "required": ["value", "range", "calculatedAt"],
      "properties": {
        "value": { "type": "integer", "minimum": 300, "maximum": 850 },
        "range": {
          "type": "object",
          "properties": {
            "min": { "type": "integer", "const": 300 },
            "max": { "type": "integer", "const": 850 }
          }
        },
        "tier": {
          "type": "string",
          "enum": ["poor", "below_average", "good", "very_good", "exceptional"]
        },
        "calculatedAt": { "type": "string", "format": "date-time" },
        "dimensions": {
          "type": "object",
          "properties": {
            "performance": { "type": "number", "minimum": 0, "maximum": 1 },
            "reliability": { "type": "number", "minimum": 0, "maximum": 1 },
            "clientImpact": { "type": "number", "minimum": 0, "maximum": 1 },
            "professionalGrowth": { "type": "number", "minimum": 0, "maximum": 1 },
            "peerTrust": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "credentialCount": { "type": "integer", "minimum": 0 },
        "window": { "type": "string" }
      }
    },
    "endorsement": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "const": "SkillEndorsement" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "relationship": {
          "type": "string",
          "enum": ["direct_manager", "peer", "client", "mentor", "other"]
        },
        "duration": { "type": "string" },
        "narrative": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "source": { "type": "string" },
        "ref": { "type": "string", "format": "uri" },
        "verifiedAt": { "type": "string", "format": "date-time" },
        "verifiedBy": { "type": "string", "pattern": "^did:" }
      }
    },
    "proof": {
      "type": "object",
      "required": ["type", "verificationMethod", "proofPurpose"],
      "properties": {
        "type": { "type": "string" },
        "cryptosuite": {
          "type": "string",
          "enum": ["ecdsa-rdfc-2022", "eddsa-rdfc-2022", "ecdsa-sd-2023", "bbs-2023"]
        },
        "created": { "type": "string", "format": "date-time" },
        "verificationMethod": { "type": "string" },
        "proofPurpose": { "type": "string", "enum": ["assertionMethod", "authentication"] },
        "proofValue": { "type": "string" },
        "challenge": { "type": "string" },
        "domain": { "type": "string" }
      }
    }
  }
}
